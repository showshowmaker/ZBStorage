# Virtual node simulator config

# Node identity and Scheduler heartbeat
NODE_ID=vpool
NODE_ADDRESS=127.0.0.1:29080
GROUP_ID=vpool-rg
NODE_ROLE=PRIMARY
# PEER_NODE_ID=vpool-standby
# PEER_ADDRESS=127.0.0.1:29081
REPLICATION_ENABLED=false
REPLICATION_TIMEOUT_MS=2000
NODE_WEIGHT=8
VIRTUAL_NODE_COUNT=100
SCHEDULER_ADDR=127.0.0.1:9100
MDS_ADDR=127.0.0.1:9000
HEARTBEAT_INTERVAL_MS=2000
ARCHIVE_REPORT_INTERVAL_MS=3000
ARCHIVE_REPORT_TOPK=256
ARCHIVE_REPORT_MIN_AGE_MS=30000
ARCHIVE_TRACK_MAX_CHUNKS=500000
ARCHIVE_META_DIR=/tmp/zb_virtual_node_meta
ARCHIVE_META_SNAPSHOT_INTERVAL_OPS=20000
ARCHIVE_META_WAL_FSYNC=false
ALLOW_DYNAMIC_DISKS=true

# Exposed disk IDs (no real mount points needed)
DISKS=disk0,disk1,disk2,disk3,disk4,disk5,disk6,disk7,disk8,disk9,disk10,disk11,disk12,disk13,disk14,disk15,disk16,disk17,disk18,disk19,disk20,disk21,disk22,disk23

# Throughput model: delay ~= base_latency + bytes / bytes_per_sec
READ_MBPS=800
WRITE_MBPS=600

# Additional fixed latency per request
READ_BASE_LATENCY_MS=2
WRITE_BASE_LATENCY_MS=3

# Random [0, JITTER_MS] latency added to each request
JITTER_MS=1

# Synthetic disk stat output for GetDiskReport
DISK_CAPACITY_BYTES=2199023255552
MOUNT_POINT_PREFIX=/virtual
